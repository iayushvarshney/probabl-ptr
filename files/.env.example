# ─── Probabl Ptr — environment ───────────────────────────────
# Copy to .env.local and fill in. Never commit .env.local.

# Supabase (from Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=          # server-side only — keep secret, used by API routes
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# HubSpot Private App token (Settings → Integrations → Private Apps)
# Scopes needed: crm.objects.contacts.read/write, crm.objects.companies.read/write,
#   crm.objects.deals.read, crm.schemas.companies.read (to confirm target-account property)
HUBSPOT_PRIVATE_APP_TOKEN=

# Anthropic
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# Auth — single shared password for the whole app
NAV_SHARED_PASSWORD=                # pick a strong one; this gates the whole app
NAV_SESSION_SECRET=                 # random 32+ char string for signing the session cookie

# Webhook shared secrets (verify incoming webhooks are really from the source)
POSTHOG_WEBHOOK_SECRET=
REO_WEBHOOK_SECRET=

# Mock flags — I have real keys, so keep these false. Flip to true to bypass a live call.
USE_MOCK_HUBSPOT=false
USE_MOCK_CLAUDE=false
